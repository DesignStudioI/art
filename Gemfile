source "https://rubygems.org"

gem "jekyll", "~> 4.4.1"

# тема
gem "minimal-mistakes-jekyll", "~> 4.27"

# плагины
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-paginate"
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
end

# Windows поддержка
platforms :mingw, :x64_mingw, :mswin do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
  gem "wdm", "~> 0.1"
end